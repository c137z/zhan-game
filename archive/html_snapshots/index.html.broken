  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  G.turn++; G.phase = 'player';
  if (G.enemyVulnerable > 0) G.enemyVulnerable--;
  log('<span class="highlight">\u23ED \u56DE\u5408' + (G.turn+1) + '\u5F00\u59CB</span>');
  log('\uD83D\uDC80HP:' + G.enemyHP + ' \uD83D\uDEE1\uFE0F' + G.enemyShield + ' \u26A1' + G.enemyPower + ' \u51CF:' + G.enemyPowerReduced);

  render(); updateEnemyIntent(); updateSpiritBomb();
  document.getElementById('btn-end-turn').disabled = true;
}

function endGame(win, msg) {
  G.over = true; G.phase = 'over';
  render(); updateSpiritBomb();
  document.getElementById('btn-end-turn').disabled = true;
  const overlay = document.getElementById('result-overlay');
  overlay.classList.add('show');
  document.getElementById('result-title').textContent = win ? '\uD83C\uDF89 \u80DC\u5229\uFF01' : '\uD83D\uDC80 \u8D25\u5317';
  document.getElementById('result-desc').textContent = msg + ' (\u5B58\u6D3B' + G.turn + '\u56DE\u5408)';
  document.getElementById('btn-reward').style.display = win ? 'inline-block' : 'none';
  document.getElementById('btn-restart').style.display = 'inline-block';
  log('<span class="highlight">' + (win ? '\uD83C\uDF89\u80DC\u5229' : '\uD83D\uDC80\u8D25\u5317') + ' ' + msg + '</span>');
}

// ─── Render ───
function render() {
  document.getElementById('player-hp').textContent = G.playerHP;
  document.getElementById('player-maxhp-label').textContent = '/' + G.playerMaxHP;
  document.getElementById('player-shield').textContent = G.playerShield;
  document.getElementById('enemy-hp').textContent = G.enemyHP;
  document.getElementById('enemy-shield').textContent = G.enemyShield;
  document.getElementById('enemy-power').textContent = G.enemyPower;

  // Player state badges
  const ps = document.getElementById('player-state');
  let badges = '';
  if (G.playerHP <= 20) badges += '<span class="state-badge" style="background:#5c1a1a;color:#e74c3c">\u26A0 \u5371\u9669</span>';
  if (G.playerAtkBoost) badges += '<span class="state-badge state-atkup">\u26A1\u653B\u51FB\u2191</span>';
  if (G.playerDefBoost) badges += '<span class="state-badge state-defup">\uD83D\uDCA8\u9632\u5FA1\u2191</span>';
  ps.innerHTML = badges;

  document.getElementById('enemy-stun-badge').style.display = G.enemyStunned ? 'block' : 'none';
  document.getElementById('enemy-vuln-badge').style.display = G.enemyVulnerable > 0 ? 'block' : 'none';

  const totalRemaining = G.piles.flat().reduce((s,p) => s + p.length, 0);
  document.getElementById('deck-remain').textContent = totalRemaining;

  let hiddenCount = 0, visibleCount = 0;
  for (const pile of G.piles.flat()) {
    if (!pile.length) continue;
    visibleCount++;
    if (pile.length > 1) hiddenCount += pile.length - 1;
  }
  document.getElementById('hidden-cards').textContent = hiddenCount;
  document.getElementById('visible-cards').textContent = visibleCount;

  renderBoard(); renderSlot(); updateSpiritBomb();
  const btn = document.getElementById('btn-end-turn');
  btn.disabled = !(G.phase === 'player' && !G.over && G.slot.length > 0);
}

function renderBoard() {
  const board = document.getElementById('board'); board.innerHTML = '';
  for (let r = 0; r < 5; r++) {
    for (let c = 0; c < 5; c++) {
      const pile = G.piles[r][c];
      const top = getTop(pile);
      const div = document.createElement('div');
      div.className = 'card-slot';
      div.dataset.r = r; div.dataset.c = c;

      if (!top) { div.classList.add('card-empty'); board.appendChild(div); continue; }

      const t = TYPE_MAP[top.type];
      const inner = document.createElement('div');
      inner.className = 'card ' + (t ? t.css : '');
      const icon = document.createElement('div'); icon.className = 'card-icon';
      icon.textContent = t ? t.icon : '?';
      inner.appendChild(icon);
      const label = document.createElement('div'); label.className = 'card-label';
      label.textContent = t ? t.name : '?';
      inner.appendChild(label);
      div.appendChild(inner);

      if (pile.length > 1) {
        const sc = document.createElement('div'); sc.className = 'stack-count';
        sc.textContent = pile.length; div.appendChild(sc);
      }

      // Double-click
      let lastTap = 0;
      div.addEventListener('click', (e) => {
        if (G.phase !== 'player' || G.over) return;
        const now = Date.now();
        if (now - lastTap < 350) {
          e.preventDefault();
          pullCard(r, c);
          lastTap = 0; return;
        }
        lastTap = now;
        if (getTop(pile)) {
          div.classList.add('double-tap-active');
          setTimeout(() => div.classList.remove('double-tap-active'), 200);
        }
      });

      // Swipe down
      let swiping = false, startY = 0, startX = 0;
      div.addEventListener('touchstart', (e) => {
        startY = e.touches[0].clientY; startX = e.touches[0].clientX; swiping = false;
      }, { passive: true });
      div.addEventListener('touchmove', (e) => {
        if (G.phase !== 'player' || G.over) return;
        const dy = e.touches[0].clientY - startY;
        const dx = Math.abs(e.touches[0].clientX - startX);
        if (dy > 20 && dy > dx * 1.5) {
          e.preventDefault();
          if (!swiping && getTop(pile)) { swiping = true; pullCard(r, c); }
        }
      }, { passive: false });

      board.appendChild(div);
    }
  }
}

function renderSlot() {
  const bar = document.getElementById('slot-bar'); bar.innerHTML = '';
  for (let i = 0; i < 10; i++) {
    const div = document.createElement('div'); div.className = 'eslot';
    if (i < G.slot.length) {
      const card = G.slot[i];
      const t = TYPE_MAP[card.type];
      div.classList.add('filled', card.type);
      div.textContent = t ? t.icon : '?';
    }
    bar.appendChild(div);
  }
}

document.getElementById('btn-end-turn').addEventListener('click', () => {
  if (G.phase !== 'player' || G.over || G.slot.length === 0) return;
  executeTurn();
});
document.getElementById('btn-reset').addEventListener('click', () => {
  document.getElementById('result-overlay').classList.remove('show');
  newGame();
});
document.getElementById('btn-restart').addEventListener('click', () => {
  document.getElementById('result-overlay').classList.remove('show');
  newGame();
});
document.getElementById('btn-reward').addEventListener('click', () => {
  document.getElementById('result-overlay').classList.remove('show');
  newGame();
});

function log(msg) {
  G.logLines.push(msg);
  if (G.logLines.length > 100) G.logLines.shift();
  const el = document.getElementById('log');
  el.innerHTML = G.logLines.map(m => '<div>' + m + '</div>').join('');
  el.scrollTop = el.scrollHeight;
}

newGame();
</script>
</body>
</html>
