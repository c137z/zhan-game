  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
  if (G.enemyDebufTurns > 0) G.enemyDebufTurns--;
